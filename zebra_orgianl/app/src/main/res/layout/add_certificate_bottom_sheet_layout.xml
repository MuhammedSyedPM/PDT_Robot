<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/bottom_sheet"
    android:background="@drawable/bottomsheet_background">

    <ImageButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/bottom_sheet_close"
        android:layout_gravity="end"
        android:layout_marginEnd="10dp"
        android:layout_marginRight="10dp"
        app:srcCompat="@drawable/ic_clear"
        android:backgroundTint="@color/white"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add New Certificate"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:textSize="20sp"
        android:textStyle="normal"
        android:layout_marginTop="10dp"/>

    <TableRow
        android:id="@+id/tbl_row_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:layout_marginStart="@dimen/default_padding_small"
        android:layout_marginEnd="@dimen/default_padding_small"
        android:layout_marginTop="@dimen/default_top_margin">

        <TextView
            style="@style/style_normal_font"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="start|center"
            android:text="TYPE" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinner_type"
            style="@style/style_default_spinner"
            android:layout_margin="0dp"
            android:layout_weight="2" />

    </TableRow>

    <TableRow
        android:id="@+id/tbl_row_cert_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:layout_marginStart="@dimen/default_padding_small"
        android:layout_marginEnd="@dimen/default_padding_small"
        android:layout_marginTop="@dimen/default_top_margin">

        <TextView
            style="@style/style_normal_font"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="start|center"
            android:text="CERT TYPE" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinner_cert_type"
            style="@style/style_default_spinner"
            android:layout_margin="0dp"
            android:layout_weight="2" />

    </TableRow>

    <TableRow
        android:id="@+id/tbl_row_edit_cert_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="@dimen/default_padding_small"
        android:layout_marginEnd="@dimen/default_padding_small"
        android:layout_marginTop="@dimen/default_top_margin">

        <TextView
            style="@style/style_normal_font"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="start|center"
            android:text="Enter Name" />

        <EditText
            android:id="@+id/et_cert_name"
            style="@style/style_default_spinner"
            android:layout_margin="0dp"
            android:layout_weight="2"
            android:hint="certificate name"
            android:imeOptions="actionDone"
            android:inputType="textAutoComplete"/>

    </TableRow>

    <TableRow
        android:id="@+id/tbl_row_select_certificate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:layout_marginStart="@dimen/default_padding_small"
        android:layout_marginEnd="@dimen/default_padding_small"
        android:layout_marginTop="@dimen/default_top_margin">

        <TextView
            style="@style/style_normal_font"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="start|center"
            android:text="Certificate" />

        <Button
            android:id="@+id/button_select_certificate"
            style="@style/style_default_spinner"
            android:layout_margin="0dp"
            android:layout_weight="2"
            android:text="SELECT CERTIFICATE"/>

    </TableRow>

    <TableRow
        android:id="@+id/tbl_row_certificate_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:layout_marginStart="@dimen/default_padding_small"
        android:layout_marginEnd="@dimen/default_padding_small"
        android:layout_marginTop="@dimen/default_top_margin">

        <TextView
            style="@style/style_normal_font"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="start|center"
            android:text="Name" />

        <TextView
            android:id="@+id/tv_cert_name"
            style="@style/style_default_spinner"
            android:layout_margin="0dp"
            android:layout_weight="2"
            android:text="certificate name"/>

    </TableRow>

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/upload_certificate"
        android:layout_margin="@dimen/default_padding"
        android:layout_marginTop="24dp"
        android:text="UPLOAD CERTIFICATE"/>



</LinearLayout>