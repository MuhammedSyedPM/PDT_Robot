<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@color/light_gray"
android:orientation="vertical"
tools:context=".scanner.fragments.SettingsFragment">
<!--<View
    android:layout_width="match_parent"
    android:layout_height="10dp"
    android:background="@color/light_gray" />
-->
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/normal_divider" />
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/generalrow"
            android:background="@android:color/white"
            android:onClick="generalSettingsClicked">

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="@string/generalSettings" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>


        <include layout="@layout/normal_divider" />
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/rfidrow"
            android:background="@android:color/white"
            android:onClick="showRFIDSettings">

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="@string/RFID"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>

        <include layout="@layout/normal_divider" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/applicationrow"
            android:background="@android:color/white"
            android:onClick="applicationSettingsClicked">

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="@string/ApplicationSettings"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/white"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>
        <include
            android:id="@+id/certificate_row_divider"
            layout="@layout/normal_divider"
            android:visibility="gone" />
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/wificertificaterow"
            android:background="@android:color/white"
            android:onClick="wifiCertificatePageClicked"
            android:visibility="gone" >

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="Certificates Management"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>
	

        <include
            android:id="@+id/scan_row_divider"
            android:visibility="invisible"
            layout="@layout/normal_divider" />
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:id="@+id/scansettingrow"
            android:onClick="scanSettingsClicked"
            android:visibility="gone">

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="@string/SCAN"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>

        <include
            android:id="@+id/wifi_row_divider"
            android:visibility="invisible"
            layout="@layout/normal_divider" />
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:id="@+id/wifisettingrow"
            android:onClick="wifiSettingsClicked"
            android:visibility="gone">

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="@string/wifi"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>
        <include
            android:id="@+id/endpoint_main_row_divider"
            layout="@layout/normal_divider"
            android:visibility="gone" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/endpointMainrow"
            android:background="@android:color/white"
            android:onClick="endpointMainPageClicked"
            android:visibility="gone" >

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="Endpoint "/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>
        <include
            android:id="@+id/admin_row_divider"
            layout="@layout/normal_divider"
            android:visibility="gone"/>
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/adminconnectrow"
            android:background="@android:color/white"
            android:visibility="gone"
            android:onClick="adminConnectClicked">

            <TextView
                style="@style/roboto_medium_16dp"
                android:layout_height="60dp"
                android:layout_marginLeft="18dp"
                android:layout_weight="0"
                android:text="@string/admin_login"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"></LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center|right"
                android:layout_marginRight="18dp"
                android:layout_weight="0"
                android:src="@drawable/right" />
        </TableRow>

<!--        <View-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="0dp"-->
<!--            android:layout_weight="45" />-->
    </LinearLayout>
</ScrollView>
</LinearLayout>